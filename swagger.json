{
  "swagger": "2.0",
  "info": {
    "title": "DMS project",
    "description": "API Documentation",
    "version": "1.0.0"
  },
  "host": "localhost:3007",
  "basePath": "/",
  "schemes": ["https"],
  "consumes": ["application/json"],
  "produces": ["application/json"],
  "paths": {

    "/admin-login": {
      "post": {
        "responses": {
          "required": {
            "description": "{ email, password }"
          }
        }
     
      
      }
    },
    "/company-signup": {
      "post": {
        "responses": {
          "required": {
            "description": "{ companyName, email, password, twillioData : {twillioSID,twillioToken,twillioNumber} }"
          }
        }
     
      
      }
    },
    "/company-login": {
      "post": {
        "responses": {
          "required": {
            "description": "{ email, password }"
          }
        }
     
      
      }
    },
    "/mediator-login": {
      "post": {
        "responses": {
          "required": {
            "description": "{ email, password }"
          }
        }
     
      
      }
    },
    "/add-mediator": {
      "post": {
        "responses": {
          "required": {
            "description": "{ firstName, lastName, email, password, phoneNumber }"
          }
        }
     
      
      }
    },
    "/refresh-token": {
      "post": {
        "responses": {
          "required": {
            "description": " { refreshToken }"
          }
        }
     
      
      }
    },
    "/forgot-password": {
      "post": {
        "responses": {
